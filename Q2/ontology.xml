<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:auto="http://www.example.org/automotive#">

   <!-- Ontology Header -->
   <owl:Ontology rdf:about="http://www.example.org/automotive#">
      <dc:title>
         Ontology for Automotive Industry.
      </dc:title>
      <dc:description>
         A comprehensive ontology mapping vehicle components, manufacturing processes,
         quality assurance workflows, and regulatory compliance standards.
      </dc:description>
   </owl:Ontology>

   <!---     Classes       -->

   <!-- Vehicle Components -->
   <owl:Class rdf:about="http://www.example.org/automotive#Vehicle">
      <rdfs:label>Vehicle</rdfs:label>
      <rdfs:comment>A road vehicle consisting of multiple electronic and mechanical subsystems.</rdfs:comment>
      <dc:description>
         Represents the main automotive product that integrates subsystems, manufacturing processes,
         security controls and compliance standards.
      </dc:description>
   </owl:Class>

   <owl:Class rdf:about="http://www.example.org/automotive#Subsystem">
      <rdfs:label>
         Vehicle Subsystem
      </rdfs:label>
      <rdfs:comment>
         A major functional unit within a vehicle.
      </rdfs:comment>
      <dc:description>
         A major functional unit of a vehicle responsible for grouping
         ECUs and mechanical parts.
      </dc:description>
   </owl:Class>

   <owl:Class rdf:about="http://www.example.org/automotive#PowertrainSystem">
      <rdfs:subClassOf rdf:resource="http://www.example.org/automotive#Subsystem"/>
      <rdfs:label>
         Powertrain System.
      </rdfs:label>
      <rdfs:comment>
         The Powertrain System includes components responsible for generating and delivering
         power to the vehicle.
      </rdfs:comment>
      <dc:description>
         Includes engine, transmission and supporting control units.
      </dc:description>
   </owl:Class>

   <owl:Class rdf:about="http://www.example.org/automotive#BrakeSystem">
      <rdfs:subClassOf rdf:resource="http://www.example.org/automotive#Subsystem"/>
      <rdfs:label>
         Brake System
      </rdfs:label>
      <rdfs:comment>
         Responsible for slowing down or stopping the vehicle.
      </rdfs:comment>
      <dc:description>
         Includes sensors, actuators and ECUs that control braking performance and safety.
      </dc:description>
   </owl:Class>

   <owl:Class rdf:about="http://www.example.org/automotive#InfotainmentSystem">
      <rdfs:subClassOf rdf:resource="http://www.example.org/automotive#Subsystem"/>
      <rdfs:label>
         Infotainment System
      </rdfs:label>
      <rdfs:comment>
         Provides in-vehicle entertainment and information services including
         navigation, and media playback, etc.
      </rdfs:comment>
      <dc:description>
         Includes navigation, multimedia playback, connectivity and user interfaces.
      </dc:description>
   </owl:Class>

   <owl:Class rdf:about="http://www.example.org/automotive#ECU">
      <rdfs:label>
         Electronic Control Unit
      </rdfs:label>
      <rdfs:comment>
         Responsible for controlling electrical systems or subsystems.
      </rdfs:comment>
      <dc:description>
         Acts as the central controller within the vehicle
         architecture.
      </dc:description>
   </owl:Class>

   <owl:Class rdf:about="http://www.example.org/automotive#Sensor">
      <rdfs:label>
         Sensor
      </rdfs:label>
      <rdfs:comment>
         A hardware device that detects and measures physical properties.
      </rdfs:comment>
      <dc:description>
         Monitors environmental and mechanical parameters
         to provide data to the ECU.
      </dc:description>
   </owl:Class>

   <owl:Class rdf:about="http://www.example.org/automotive#Actuator">
      <rdfs:label>
         Actuator
      </rdfs:label>
      <rdfs:comment>
         A component responsible for moving or controlling a mechanism or system.
      </rdfs:comment>
      <dc:description>
         Executes physical actions, such as braking, based on ECU commands.
      </dc:description>
   </owl:Class>

   <owl:Class rdf:about="http://www.example.org/automotive#PhysicalParameter">
      <rdfs:label>Physical Parameter</rdfs:label>
      <rdfs:comment>A measurable characteristic of the vehicle state.</rdfs:comment>
      <dc:description>
         Includes variables like speed, pressure, temperature, and voltage.
      </dc:description>
   </owl:Class>

   <!-- Manufacturing -->
   <owl:Class rdf:about="http://www.example.org/automotive#ManufacturingProcess">
      <rdfs:label>Manufacturing Process</rdfs:label>
      <rdfs:comment>
         Industrial workflow used to produce vehicle parts.
      </rdfs:comment>
      <dc:description>Industrial workflows used in vehicle production, such as stamping or assembly.</dc:description>
   </owl:Class>

   <owl:Class rdf:about="http://www.example.org/automotive#Material">
      <rdfs:label>Material</rdfs:label>
      <rdfs:comment>Raw substances used in the production of vehicle parts.</rdfs:comment>
      <dc:description>
         Includes metals, plastics amd composites used in automotive engineering.
      </dc:description>
   </owl:Class>

   <owl:Class rdf:about="http://www.example.org/automotive#ProductionMethodology">
      <rdfs:label>Production Methodology</rdfs:label>
      <rdfs:comment>
         Management framework guiding manufacturing.
      </rdfs:comment>
      <dc:description>Management frameworks like Just-in-Time (JIT).</dc:description>
   </owl:Class>

   <owl:Class rdf:about="http://www.example.org/automotive#FactoryTechnology">
      <rdfs:label>Factory Technology</rdfs:label>
      <rdfs:comment>
         Advanced technology used in factories.
      </rdfs:comment>
      <dc:description>Advanced tools used on the shop floor, including AGVs and Digital Twins.</dc:description>
   </owl:Class>

   <!-- QA -->
   <owl:Class rdf:about="http://www.example.org/automotive#QAActivity">
      <rdfs:label>Quality Assurance Activity</rdfs:label>
      <rdfs:comment>
         Process verifying safety, quality and reliability.
      </rdfs:comment>
      <dc:description>Systematic processes for verifying that components meet safety and performance specs.</dc:description>
   </owl:Class>

   <owl:Class rdf:about="http://www.example.org/automotive#Defect">
      <rdfs:label>Defect</rdfs:label>
      <rdfs:comment>An imperfection or failure in a component or process.</rdfs:comment>
      <dc:description>
         Represent the failures detected during testing.
      </dc:description>
   </owl:Class>

   <owl:Class rdf:about="http://www.example.org/automotive#Documentation">
      <rdfs:label>Documentation</rdfs:label>
      <rdfs:comment>
         Records used for traceability and compliance.
      </rdfs:comment>
      <dc:description>Traceable records and reports required for audits and compliance.</dc:description>
   </owl:Class>

   <!-- Compliance -->
   <owl:Class rdf:about="http://www.example.org/automotive#Standard">
      <rdfs:label>Standard</rdfs:label>
      <rdfs:comment>
         Formal ISO.
      </rdfs:comment>
      <dc:description>Formal ISO or IATF frameworks governing automotive quality and security.</dc:description>
   </owl:Class>

   <!-- Security and Maintenance-->
   <owl:Class rdf:about="http://www.example.org/automotive#SecurityMeasure">
      <rdfs:label>Security Measure</rdfs:label>
      <rdfs:comment>
         Protection against cyber-physical threats.
      </rdfs:comment>
      <dc:description>Hardware or software safeguards designed to protect the vehicle from cyber-physical threats.</dc:description>
   </owl:Class>

   <owl:Class rdf:about="http://www.example.org/automotive#MaintenanceActivity">
      <rdfs:label>Maintenance Activity</rdfs:label>
      <rdfs:comment>
         Ensures vehicle reliability.
      </rdfs:comment>
      <dc:description>Preventive tasks performed to ensure vehicle reliability.</dc:description>
   </owl:Class>


   <!-- Object Properties -->
   <owl:ObjectProperty rdf:about="http://www.example.org/automotive#hasSubSystem"/>
   <owl:ObjectProperty rdf:about="http://www.example.org/automotive#requiresStandard"/>
   <owl:ObjectProperty rdf:about="http://www.example.org/automotive#producedByProcess"/>
   <owl:ObjectProperty rdf:about="http://www.example.org/automotive#containsECU"/>
   <owl:ObjectProperty rdf:about="http://www.example.org/automotive#controlsSensor"/>
   <owl:ObjectProperty rdf:about="http://www.example.org/automotive#controlsActuator"/>
   <owl:ObjectProperty rdf:about="http://www.example.org/automotive#monitorsParameter"/>
   <owl:ObjectProperty rdf:about="http://www.example.org/automotive#processUsesMaterial"/>
   <owl:ObjectProperty rdf:about="http://www.example.org/automotive#processFollowsMethodology"/>
   <owl:ObjectProperty rdf:about="http://www.example.org/automotive#detectsDefect"/>
   <owl:ObjectProperty rdf:about="http://www.example.org/automotive#factoryUsesTechnology"/>
   <owl:ObjectProperty rdf:about="http://www.example.org/automotive#qaDocuments"/>
   <owl:ObjectProperty rdf:about="http://www.example.org/automotive#qaEnsuresCompliance"/>
   <owl:ObjectProperty rdf:about="http://www.example.org/automotive#securityProtects"/>
   <owl:ObjectProperty rdf:about="http://www.example.org/automotive#maintenanceAppliedTo"/>
   <owl:ObjectProperty rdf:about="http://www.example.org/automotive#monitorsProcess"/>
   <owl:ObjectProperty rdf:about="http://www.example.org/automotive#supportsStandard"/>
   <owl:ObjectProperty rdf:about="http://www.example.org/automotive#supportsProcess"/>
   <owl:ObjectProperty rdf:about="http://www.example.org/automotive#vehicleCompliesWith"/>

   <!--     Individuals     -->

   <!-- Vehicle branch -->
   <rdf:Description rdf:about="http://www.example.org/automotive#CarModelX">
      <rdf:type rdf:resource="http://www.example.org/automotive#Vehicle"/>
      <auto:hasSubSystem rdf:resource="http://www.example.org/automotive#Powertrain"/>
      <auto:hasSubSystem rdf:resource="http://www.example.org/automotive#BrakeSystemX"/>
      <auto:producedByProcess rdf:resource="http://www.example.org/automotive#Stamping"/>
      <auto:producedByProcess rdf:resource="http://www.example.org/automotive#InjectionMoulding"/>
      <auto:vehicleCompliesWith rdf:resource="http://www.example.org/automotive#ISO27001"/>
   </rdf:Description>

   <rdf:Description rdf:about="http://www.example.org/automotive#Powertrain">
      <rdf:type rdf:resource="http://www.example.org/automotive#PowertrainSystem"/>
      <auto:containsECU rdf:resource="http://www.example.org/automotive#EngineECU"/>
   </rdf:Description>

   <rdf:Description rdf:about="http://www.example.org/automotive#BrakeSystemX">
      <rdf:type rdf:resource="http://www.example.org/automotive#BrakeSystem"/>
   </rdf:Description>

   <rdf:Description rdf:about="http://www.example.org/automotive#EngineECU">
      <rdf:type rdf:resource="http://www.example.org/automotive#ECU"/>
      <auto:controlsSensor rdf:resource="http://www.example.org/automotive#TemperatureSensor"/>
      <auto:controlsActuator rdf:resource="http://www.example.org/automotive#BrakeActuator"/>
      <auto:requiresStandard rdf:resource="http://www.example.org/automotive#ISO27001"/>
      <auto:requiresStandard rdf:resource="http://www.example.org/automotive#ISO27701"/>
   </rdf:Description>

   <rdf:Description rdf:about="http://www.example.org/automotive#TemperatureSensor">
      <rdf:type rdf:resource="http://www.example.org/automotive#Sensor"/>
      <auto:monitorsParameter rdf:resource="http://www.example.org/automotive#EngineTemperature"/>
   </rdf:Description>

   <rdf:Description rdf:about="http://www.example.org/automotive#BrakeActuator">
      <rdf:type rdf:resource="http://www.example.org/automotive#Actuator"/>
   </rdf:Description>

   <rdf:Description rdf:about="http://www.example.org/automotive#EngineTemperature">
      <rdf:type rdf:resource="http://www.example.org/automotive#PhysicalParameter"/>
   </rdf:Description>

   <!-- Manufacturing-->
   <rdf:Description rdf:about="http://www.example.org/automotive#Stamping">
      <rdf:type rdf:resource="http://www.example.org/automotive#ManufacturingProcess"/>
      <auto:processUsesMaterial rdf:resource="http://www.example.org/automotive#Steel"/>
      <auto:processFollowsMethodology rdf:resource="http://www.example.org/automotive#JIT"/>
      <auto:factoryUsesTechnology rdf:resource="http://www.example.org/automotive#AGV"/>
   </rdf:Description>

   <rdf:Description rdf:about="http://www.example.org/automotive#InjectionMoulding">
      <rdf:type rdf:resource="http://www.example.org/automotive#ManufacturingProcess"/>
   </rdf:Description>

   <rdf:Description rdf:about="http://www.example.org/automotive#Steel">
      <rdf:type rdf:resource="http://www.example.org/automotive#Material"/>
   </rdf:Description>

   <rdf:Description rdf:about="http://www.example.org/automotive#JIT">
      <rdf:type rdf:resource="http://www.example.org/automotive#ProductionMethodology"/>
   </rdf:Description>

   <rdf:Description rdf:about="http://www.example.org/automotive#AGV">
      <rdf:type rdf:resource="http://www.example.org/automotive#FactoryTechnology"/>
      <auto:supportsProcess rdf:resource="http://www.example.org/automotive#InjectionMoulding"/>
   </rdf:Description>

   <rdf:Description rdf:about="http://www.example.org/automotive#DigitalTwin">
      <rdf:type rdf:resource="http://www.example.org/automotive#FactoryTechnology"/>
   </rdf:Description>

   <!-- QA  -->
   <rdf:Description rdf:about="http://www.example.org/automotive#CrashTest">
      <rdf:type rdf:resource="http://www.example.org/automotive#QAActivity"/>
      <auto:qaDocuments rdf:resource="http://www.example.org/automotive#InspectionReport"/>
      <auto:qaEnsuresCompliance rdf:resource="http://www.example.org/automotive#IATF16949"/>
      <auto:detectsDefect rdf:resource="http://www.example.org/automotive#BrakeFailure"/>
   </rdf:Description>

   <rdf:Description rdf:about="http://www.example.org/automotive#InspectionReport">
      <rdf:type rdf:resource="http://www.example.org/automotive#Documentation"/>
   </rdf:Description>

   <rdf:Description rdf:about="http://www.example.org/automotive#InspectionReportX">
      <rdf:type rdf:resource="http://www.example.org/automotive#Documentation"/>
      <dc:title>
         Stamping Quality Report
      </dc:title>
      <auto:supportsStandard rdf:resource="http://www.example.org/automotive#IATF16949"/>
   </rdf:Description>

   <rdf:Description rdf:about="http://www.example.org/automotive#BrakeFailure">
      <rdf:type rdf:resource="http://www.example.org/automotive#Defect"/>
   </rdf:Description>

   <!-- Standards -->
   <rdf:Description rdf:about="http://www.example.org/automotive#IATF16949">
      <rdf:type rdf:resource="http://www.example.org/automotive#Standard"/>
   </rdf:Description>

   <rdf:Description rdf:about="http://www.example.org/automotive#ISO27001">
      <rdf:type rdf:resource="http://www.example.org/automotive#Standard"/>
   </rdf:Description>

   <rdf:Description rdf:about="http://www.example.org/automotive#ISO27701">
      <rdf:type rdf:resource="http://www.example.org/automotive#Standard"/>
   </rdf:Description>

   <rdf:Description rdf:about="http://www.example.org/automotive#ISO22301">
      <rdf:type rdf:resource="http://www.example.org/automotive#Standard"/>
   </rdf:Description>

   <rdf:Description rdf:about="http://www.example.org/automotive#ISO14001">
      <rdf:type rdf:resource="http://www.example.org/automotive#Standard"/>
   </rdf:Description>

   <rdf:Description rdf:about="http://www.example.org/automotive#ISO45001">
      <rdf:type rdf:resource="http://www.example.org/automotive#Standard"/>
   </rdf:Description>

   <!-- Security and Maintenance    -->
   <rdf:Description rdf:about="http://www.example.org/automotive#SecureBoot">
      <rdf:type rdf:resource="http://www.example.org/automotive#SecurityMeasure"/>
      <auto:securityProtects rdf:resource="http://www.example.org/automotive#CarModelX"/>
   </rdf:Description>

   <rdf:Description rdf:about="http://www.example.org/automotive#SecureBootX">
      <rdf:type rdf:resource="http://www.example.org/automotive#SecurityMeasure"/>
      <rdfs:label>Hardware Secure Boot</rdfs:label>
      <dc:description>Prevents unauthorized firmware from executing during the ECU startup phase.</dc:description>
      <auto:securityProtects rdf:resource="http://www.example.org/automotive#CarModelX"/>
   </rdf:Description>

   <rdf:Description rdf:about="http://www.example.org/automotive#OilChange">
      <rdf:type rdf:resource="http://www.example.org/automotive#MaintenanceActivity"/>
      <auto:maintenanceAppliedTo rdf:resource="http://www.example.org/automotive#CarModelX"/>
   </rdf:Description>

   <rdf:Description rdf:about="http://www.example.org/automotive#BrakeInspection">
      <rdf:type rdf:resource="http://www.example.org/automotive#MaintenanceActivity"/>
      <auto:maintenanceAppliedTo rdf:resource="http://www.example.org/automotive#CarModelX"/>
   </rdf:Description>

   <rdf:Description rdf:about="http://www.example.org/automotive#BatteryInspection">
      <rdf:type rdf:resource="http://www.example.org/automotive#MaintenanceActivity"/>
      <auto:maintenanceAppliedTo rdf:resource="http://www.example.org/automotive#CarModelX"/>
   </rdf:Description>
</rdf:RDF>
