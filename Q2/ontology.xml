   <rdf:Description rdf:about="http://www.example.org/automotive#IATF16949">
      <rdf:type rdf:resource="http://www.example.org/automotive#Standard"/>
   </rdf:Description>

   <rdf:Description rdf:about="http://www.example.org/automotive#ISO27001">
